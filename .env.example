# DeepSeek_Web_To_API runtime environment template
#
# Main application settings live in config.json. Copy config.example.json to
# config.json and fill admin.key, admin.jwt_secret, keys, and accounts there.
# Keep this file for deployment-layer overrides that must exist before
# config.json can be read, or for platform/serverless injection.

# Docker Compose host port only. The container and app still listen on
# server.port from config.json unless PORT is set by the platform.
DEEPSEEK_WEB_TO_API_HOST_PORT=6011

# Optional: choose where the single runtime config file is loaded from.
# For Docker Compose, docker-compose.yml sets this to /data/config.json.
# DEEPSEEK_WEB_TO_API_CONFIG_PATH=config.json

# Optional: serverless / platform deployments can inject config.json as raw
# JSON or Base64 JSON. Prefer generating this from the same config.json file.
# DEEPSEEK_WEB_TO_API_CONFIG_JSON=

# Optional deployment-only admin overrides. Prefer config.json for normal
# deployments so the Admin UI and exported config stay consistent.
# DEEPSEEK_WEB_TO_API_ADMIN_KEY=
# DEEPSEEK_WEB_TO_API_JWT_SECRET=
# DEEPSEEK_WEB_TO_API_JWT_EXPIRE_HOURS=24

# Optional server/runtime overrides. Prefer config.json unless your platform
# requires env vars.
# PORT=5001
# LOG_LEVEL=INFO
# DEEPSEEK_WEB_TO_API_BIND_ADDR=0.0.0.0
# DEEPSEEK_WEB_TO_API_STATIC_ADMIN_DIR=static/admin
# DEEPSEEK_WEB_TO_API_AUTO_BUILD_WEBUI=true
# DEEPSEEK_WEB_TO_API_HTTP_TOTAL_TIMEOUT_SECONDS=7200

# Optional data path overrides. Prefer storage/cache sections in config.json.
# DEEPSEEK_WEB_TO_API_CHAT_HISTORY_PATH=data/chat_history.json
# DEEPSEEK_WEB_TO_API_CHAT_HISTORY_SQLITE_PATH=data/chat_history.sqlite
# DEEPSEEK_WEB_TO_API_RAW_STREAM_SAMPLE_ROOT=tests/raw_stream_samples
# DEEPSEEK_WEB_TO_API_RESPONSE_CACHE_DIR=data/response_cache

# Optional concurrency overrides. Prefer runtime section in config.json.
# DEEPSEEK_WEB_TO_API_ACCOUNT_MAX_INFLIGHT=2
# DEEPSEEK_WEB_TO_API_ACCOUNT_MAX_QUEUE=0
# DEEPSEEK_WEB_TO_API_GLOBAL_MAX_INFLIGHT=0

# Optional compatibility / operations flags.
# DEEPSEEK_WEB_TO_API_ENV_WRITEBACK=false
# DEEPSEEK_WEB_TO_API_ALLOW_QUERY_AUTH=false
# DEEPSEEK_WEB_TO_API_AUTO_CONTINUE_ROUNDS=0

# Optional stream tuning. Defaults are safe for long Claude Code / Codex runs.
# DEEPSEEK_WEB_TO_API_STREAM_KEEPALIVE_INTERVAL_SECONDS=5
# DEEPSEEK_WEB_TO_API_STREAM_IDLE_TIMEOUT_SECONDS=1800
# DEEPSEEK_WEB_TO_API_STREAM_MAX_KEEPALIVE_NO_CONTENT=360
