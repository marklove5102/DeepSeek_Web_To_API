# DeepSeek_Web_To_API 运行时环境变量模板
#
# 新部署推荐以本 .env 为主入口：把结构化配置写入下方 DEEPSEEK_WEB_TO_API_CONFIG_JSON，
# 然后在管理台用「邮箱:密码」格式批量导入账号——账号会写入独立的 SQLite，无需混入 JSON。
# 同名 config.example.json 是相同字段的展开版（人类可读），二者等价；运行时若两边都存在，
# CONFIG_JSON 优先，并在管理台保存配置时自动同步回写到 CONFIG_PATH 指向的文件。

# Docker Compose 宿主机映射端口；容器内仍按 server.port（CONFIG_JSON 中）监听，除非显式设置 PORT。
DEEPSEEK_WEB_TO_API_HOST_PORT=6011

# 主结构化配置。请在使用前替换 api_keys 与 admin 中的 change-me-* 占位符。
# 也可填管理台导出的 base64 形式：base64:<value>。
DEEPSEEK_WEB_TO_API_CONFIG_JSON='{"api_keys":[{"key":"your-api-key-1","name":"主 API Key","remark":"给 OpenAI 客户端使用"},{"key":"your-api-key-2","name":"备用 API Key","remark":"压测或临时调试"}],"proxies":[{"id":"proxy-main","name":"主代理","type":"socks5h","host":"127.0.0.1","port":1080,"username":"","password":""}],"model_aliases":{"gpt-4o":"deepseek-v4-flash","gpt-5.5":"deepseek-v4-flash","gpt-5.3-codex":"deepseek-v4-pro","o3":"deepseek-v4-pro"},"admin":{"key":"change-me-admin-key","password_hash":"","jwt_secret":"change-me-jwt-secret","jwt_expire_hours":24,"jwt_valid_after_unix":0},"server":{"port":"5001","bind_addr":"127.0.0.1","log_level":"INFO","static_admin_dir":"static/admin","auto_build_webui":true,"http_total_timeout_seconds":7200,"remote_file_upload_enabled":false},"storage":{"data_dir":"data","accounts_sqlite_path":"data/accounts.sqlite","chat_history_path":"data/chat_history.json","chat_history_sqlite_path":"data/chat_history.sqlite","token_usage_sqlite_path":"data/token_usage.sqlite","safety_words_sqlite_path":"data/safety_words.sqlite","safety_ips_sqlite_path":"data/safety_ips.sqlite","raw_stream_sample_root":"tests/raw_stream_samples"},"cache":{"response":{"dir":"data/response_cache","memory_ttl_seconds":1800,"memory_max_bytes":3800000000,"disk_ttl_seconds":86400,"disk_max_bytes":16000000000,"max_body_bytes":67108864,"semantic_key":true}},"safety":{"enabled":false,"block_message":"request blocked by safety policy","blocked_ips":[],"blocked_conversation_ids":[],"banned_content":[],"banned_regex":[],"jailbreak":{"enabled":false,"patterns":[]}},"runtime":{"account_max_inflight":2,"account_max_queue":0,"global_max_inflight":0,"token_refresh_interval_hours":6},"responses":{"store_ttl_seconds":900},"current_input_file":{"enabled":true,"min_chars":0},"thinking_injection":{"enabled":true,"prompt":""},"embeddings":{"provider":"deterministic"},"auto_delete":{"mode":"none","sessions":false},"history_split":{"enabled":false,"trigger_after_turns":1},"compat":{"wide_input_strict_output":true,"strip_reference_markers":true}}'

# 写回开关：开启时，管理台修改后的配置会同步回写到下方 CONFIG_PATH 指向的文件，
# 重启后两端保持一致。请确保 data/ 已挂载持久化卷。
DEEPSEEK_WEB_TO_API_ENV_WRITEBACK=true
DEEPSEEK_WEB_TO_API_CONFIG_PATH=data/config.json

# 独立账号 SQLite 路径；强烈建议放在持久化卷内。
DEEPSEEK_WEB_TO_API_ACCOUNTS_SQLITE_PATH=data/accounts.sqlite

# 可选：管理员凭据覆盖（优先级高于 CONFIG_JSON 内的 admin.*）。
# DEEPSEEK_WEB_TO_API_ADMIN_KEY=
# DEEPSEEK_WEB_TO_API_JWT_SECRET=
# DEEPSEEK_WEB_TO_API_JWT_EXPIRE_HOURS=24

# 可选：服务器/运行时覆盖（优先级高于 CONFIG_JSON 内的 server.*）。
# PORT=5001
# LOG_LEVEL=INFO
# DEEPSEEK_WEB_TO_API_BIND_ADDR=127.0.0.1
# DEEPSEEK_WEB_TO_API_STATIC_ADMIN_DIR=static/admin
# DEEPSEEK_WEB_TO_API_AUTO_BUILD_WEBUI=true
# DEEPSEEK_WEB_TO_API_HTTP_TOTAL_TIMEOUT_SECONDS=7200

# 各类持久化文件路径覆盖。每类数据存放在独立 SQLite，便于单独备份/轮转。
# DEEPSEEK_WEB_TO_API_CHAT_HISTORY_PATH=data/chat_history.json
DEEPSEEK_WEB_TO_API_CHAT_HISTORY_SQLITE_PATH=data/chat_history.sqlite
DEEPSEEK_WEB_TO_API_TOKEN_USAGE_SQLITE_PATH=data/token_usage.sqlite
DEEPSEEK_WEB_TO_API_SAFETY_WORDS_SQLITE_PATH=data/safety_words.sqlite
DEEPSEEK_WEB_TO_API_SAFETY_IPS_SQLITE_PATH=data/safety_ips.sqlite
DEEPSEEK_WEB_TO_API_RAW_STREAM_SAMPLE_ROOT=tests/raw_stream_samples
DEEPSEEK_WEB_TO_API_RESPONSE_CACHE_DIR=data/response_cache
DEEPSEEK_WEB_TO_API_RESPONSE_CACHE_SEMANTIC_KEY=true

# 文件上传开关。生产默认 false：附件直接内联到对话上下文，不调用上游 upload_file
# （避免账号级速率限制拖垮成功率）。仅当账号池有充足配额时才考虑置为 true。
# DEEPSEEK_WEB_TO_API_REMOTE_FILE_UPLOAD_ENABLED=false

# 并发控制覆盖（优先级高于 CONFIG_JSON 内的 runtime.*）。
# DEEPSEEK_WEB_TO_API_ACCOUNT_MAX_INFLIGHT=2
# DEEPSEEK_WEB_TO_API_ACCOUNT_MAX_QUEUE=0
# DEEPSEEK_WEB_TO_API_GLOBAL_MAX_INFLIGHT=0

# 兼容性 / 运维开关。
# DEEPSEEK_WEB_TO_API_ALLOW_QUERY_AUTH=false
# DEEPSEEK_WEB_TO_API_AUTO_CONTINUE_ROUNDS=0

# 流式调优。默认值适合长会话（Claude Code / Codex / OpenCode 等代理工作流）。
# DEEPSEEK_WEB_TO_API_STREAM_KEEPALIVE_INTERVAL_SECONDS=5
# DEEPSEEK_WEB_TO_API_STREAM_IDLE_TIMEOUT_SECONDS=1800
# DEEPSEEK_WEB_TO_API_STREAM_MAX_KEEPALIVE_NO_CONTENT=360
