# DeepSeek_Web_To_API runtime environment template
#
# New deployments should use this .env as the primary runtime entrypoint.
# Put the structured config in DEEPSEEK_WEB_TO_API_CONFIG_JSON, then use the
# Admin UI to add accounts in account:password text format. Accounts are stored
# separately in SQLite and no longer need to be maintained in JSON.

# Docker Compose host port. The app inside the container still listens on
# server.port from DEEPSEEK_WEB_TO_API_CONFIG_JSON unless PORT is set.
DEEPSEEK_WEB_TO_API_HOST_PORT=6011

# Primary structured config. Replace the keys and admin secrets before running.
# You may also paste the Base64 value exported by the Admin UI as base64:<value>.
DEEPSEEK_WEB_TO_API_CONFIG_JSON='{"api_keys":[{"key":"change-me-client-key","name":"default","remark":"external clients"}],"admin":{"key":"change-me-admin-key","jwt_secret":"change-me-jwt-secret","jwt_expire_hours":24},"server":{"port":"5001","bind_addr":"127.0.0.1","log_level":"INFO","static_admin_dir":"static/admin","auto_build_webui":true,"http_total_timeout_seconds":7200},"storage":{"data_dir":"data","accounts_sqlite_path":"data/accounts.sqlite","chat_history_sqlite_path":"data/chat_history.sqlite","chat_history_path":"data/chat_history.json","raw_stream_sample_root":"tests/raw_stream_samples"},"cache":{"response":{"dir":"data/response_cache","memory_ttl_seconds":300,"memory_max_bytes":3800000000,"disk_ttl_seconds":14400,"disk_max_bytes":16000000000,"max_body_bytes":67108864,"semantic_key":true}},"safety":{"enabled":false,"block_message":"request blocked by safety policy","blocked_ips":[],"blocked_conversation_ids":[],"banned_content":[],"banned_regex":[],"jailbreak":{"enabled":false,"patterns":[]}},"runtime":{"account_max_inflight":2,"account_max_queue":0,"global_max_inflight":0,"token_refresh_interval_hours":6},"responses":{"store_ttl_seconds":900},"current_input_file":{"enabled":true,"min_chars":0},"thinking_injection":{"enabled":true,"prompt":""},"embeddings":{"provider":"deterministic"},"auto_delete":{"mode":"none","sessions":false},"compat":{"wide_input_strict_output":true,"strip_reference_markers":true}}'

# Optional writeback: when enabled, the initial env JSON is bootstrapped to the
# path below and later Admin UI edits are persisted there. Keep data/ mounted.
DEEPSEEK_WEB_TO_API_ENV_WRITEBACK=true
DEEPSEEK_WEB_TO_API_CONFIG_PATH=data/config.json

# Independent account SQLite store. Keep this path on persistent storage.
DEEPSEEK_WEB_TO_API_ACCOUNTS_SQLITE_PATH=data/accounts.sqlite

# Optional deployment-only admin overrides. These override the structured config.
# DEEPSEEK_WEB_TO_API_ADMIN_KEY=
# DEEPSEEK_WEB_TO_API_JWT_SECRET=
# DEEPSEEK_WEB_TO_API_JWT_EXPIRE_HOURS=24

# Optional server/runtime overrides.
# PORT=5001
# LOG_LEVEL=INFO
# DEEPSEEK_WEB_TO_API_BIND_ADDR=127.0.0.1
# DEEPSEEK_WEB_TO_API_STATIC_ADMIN_DIR=static/admin
# DEEPSEEK_WEB_TO_API_AUTO_BUILD_WEBUI=true
# DEEPSEEK_WEB_TO_API_HTTP_TOTAL_TIMEOUT_SECONDS=7200

# Optional data path overrides.
# DEEPSEEK_WEB_TO_API_CHAT_HISTORY_PATH=data/chat_history.json
# DEEPSEEK_WEB_TO_API_CHAT_HISTORY_SQLITE_PATH=data/chat_history.sqlite
# DEEPSEEK_WEB_TO_API_RAW_STREAM_SAMPLE_ROOT=tests/raw_stream_samples
# DEEPSEEK_WEB_TO_API_RESPONSE_CACHE_DIR=data/response_cache
# DEEPSEEK_WEB_TO_API_RESPONSE_CACHE_SEMANTIC_KEY=true

# Optional concurrency overrides.
# DEEPSEEK_WEB_TO_API_ACCOUNT_MAX_INFLIGHT=2
# DEEPSEEK_WEB_TO_API_ACCOUNT_MAX_QUEUE=0
# DEEPSEEK_WEB_TO_API_GLOBAL_MAX_INFLIGHT=0

# Optional compatibility / operations flags.
# DEEPSEEK_WEB_TO_API_ALLOW_QUERY_AUTH=false
# DEEPSEEK_WEB_TO_API_AUTO_CONTINUE_ROUNDS=0

# Optional stream tuning. Defaults are safe for long Claude Code / Codex runs.
# DEEPSEEK_WEB_TO_API_STREAM_KEEPALIVE_INTERVAL_SECONDS=5
# DEEPSEEK_WEB_TO_API_STREAM_IDLE_TIMEOUT_SECONDS=1800
# DEEPSEEK_WEB_TO_API_STREAM_MAX_KEEPALIVE_NO_CONTENT=360
