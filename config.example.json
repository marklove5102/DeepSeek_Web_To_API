{
  "api_keys": [
    {
      "key": "your-api-key-1",
      "name": "主 API Key",
      "remark": "给 OpenAI 客户端使用"
    },
    {
      "key": "your-api-key-2",
      "name": "备用 API Key",
      "remark": "压测或临时调试"
    }
  ],
  "proxies": [
    {
      "id": "proxy-main",
      "name": "主代理",
      "type": "socks5h",
      "host": "127.0.0.1",
      "port": 1080,
      "username": "",
      "password": ""
    }
  ],
  "model_aliases": {
    "gpt-4o": "deepseek-v4-flash",
    "gpt-5.5": "deepseek-v4-flash",
    "gpt-5.3-codex": "deepseek-v4-pro",
    "o3": "deepseek-v4-pro"
  },
  "admin": {
    "key": "change-me-admin-key",
    "password_hash": "",
    "jwt_secret": "change-me-jwt-secret",
    "jwt_expire_hours": 24,
    "jwt_valid_after_unix": 0
  },
  "server": {
    "port": "5001",
    "bind_addr": "127.0.0.1",
    "log_level": "INFO",
    "static_admin_dir": "static/admin",
    "auto_build_webui": true,
    "http_total_timeout_seconds": 7200,
    "remote_file_upload_enabled": false
  },
  "storage": {
    "data_dir": "data",
    "accounts_sqlite_path": "data/accounts.sqlite",
    "chat_history_path": "data/chat_history.json",
    "chat_history_sqlite_path": "data/chat_history.sqlite",
    "token_usage_sqlite_path": "data/token_usage.sqlite",
    "safety_words_sqlite_path": "data/safety_words.sqlite",
    "safety_ips_sqlite_path": "data/safety_ips.sqlite",
    "raw_stream_sample_root": "tests/raw_stream_samples"
  },
  "cache": {
    "response": {
      "dir": "data/response_cache",
      "memory_ttl_seconds": 1800,
      "memory_max_bytes": 3800000000,
      "disk_ttl_seconds": 86400,
      "disk_max_bytes": 16000000000,
      "max_body_bytes": 67108864,
      "semantic_key": true
    }
  },
  "safety": {
    "enabled": false,
    "block_message": "request blocked by safety policy",
    "blocked_ips": [],
    "blocked_conversation_ids": [],
    "banned_content": [],
    "banned_regex": [],
    "jailbreak": {
      "enabled": false,
      "patterns": []
    }
  },
  "runtime": {
    "account_max_inflight": 2,
    "account_max_queue": 0,
    "global_max_inflight": 0,
    "token_refresh_interval_hours": 6
  },
  "responses": {
    "store_ttl_seconds": 900
  },
  "current_input_file": {
    "enabled": true,
    "min_chars": 0
  },
  "thinking_injection": {
    "enabled": true,
    "prompt": ""
  },
  "embeddings": {
    "provider": "deterministic"
  },
  "auto_delete": {
    "mode": "none",
    "sessions": false
  },
  "history_split": {
    "enabled": false,
    "trigger_after_turns": 1
  },
  "compat": {
    "wide_input_strict_output": true,
    "strip_reference_markers": true
  }
}
